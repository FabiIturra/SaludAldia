      "name": "01 - List document categories",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Has categories', function () { const j = pm.response.json(); pm.expect(j.status).to.eql('success'); pm.expect(j.categories).to.be.an('array'); });"
